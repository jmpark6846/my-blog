# Database (Payload uses Postgres via @payloadcms/db-postgres)
# Local: postgresql://127.0.0.1:5432/your-database-name
#
# Supabase (Dashboard → Project Settings → Database → Connection string):
# Prefer "URI" under "Direct connection" for builds (migrations) + runtime on Vercel.
# Append ssl mode, e.g. ?sslmode=require
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require
#
# If you use the pooler (port 6543, transaction mode), some DDL migrations can fail;
# use direct URI for DATABASE_URL unless you split migrate vs runtime URLs in your workflow.
DATABASE_URL=postgresql://127.0.0.1:5432/your-database-name

# Used to encrypt JWT tokens (generate a long random string for production)
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash.
# On Vercel you can rely on VERCEL_PROJECT_PRODUCTION_URL; setting this to your live URL is still fine.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs (Vercel Cron sends Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate draft preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE
